# Morning Brief 환경변수 예시. 실제 값을 채워 .env로 복사하거나 CI 시크릿으로 등록하세요.
# 아무것도 설정하지 않아도 --fixtures 모드로 데모 사이트가 생성됩니다.

# ── 텔레그램 수집 (라이브 모드) ───────────────────────────────
# https://my.telegram.org 에서 API ID/HASH 발급.
# TELEGRAM_SESSION 은 Telethon StringSession 문자열입니다. 발급 방법:
#   python - <<'PY'
#   from telethon.sync import TelegramClient
#   from telethon.sessions import StringSession
#   api_id=int(input("api_id: ")); api_hash=input("api_hash: ")
#   with TelegramClient(StringSession(), api_id, api_hash) as c:
#       print(c.session.save())
#   PY
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_CHANNEL=ehdwl

# ── Claude 요약 (라이브 모드) ─────────────────────────────────
ANTHROPIC_API_KEY=
MORNING_BRIEF_MODEL=claude-opus-4-8

# ── 동작 옵션 ────────────────────────────────────────────────
MORNING_BRIEF_TZ=Asia/Seoul
MORNING_BRIEF_OUT=site
MORNING_BRIEF_CHART_DAYS=20
